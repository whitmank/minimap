{
    "manifest_version": 3,
    "name": "Mini Map - DENO",
    "version": "1.0",
    "permissions": [
        "windows",
        "tabs",
        "activeTab",
        "browsingData"
    ],
    "chrome_url_overrides": {
        "newtab": "./src/chrome/map.html"
    },
    "background": {
        "service_worker": "/src/chrome/background.js"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}